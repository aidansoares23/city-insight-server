# ── Required ────────────────────────────────────────────────────────────────

# Absolute path to your Firebase service account JSON key.
# In Firebase Console: Project Settings → Service Accounts → Generate new private key.
# Do NOT commit this file.
FIREBASE_SERVICE_ACCOUNT_PATH=/absolute/path/to/serviceAccount.json

# Secret used to sign session JWTs. Generate with: openssl rand -hex 32
# Can be rotated — existing sessions will be invalidated.
SESSION_JWT_SECRET=

# Salt for deterministic review ID generation. Generate with: openssl rand -hex 32
# NEVER change after launch — changing this orphans all existing reviews.
REVIEW_ID_SALT=

# Google OAuth 2.0 client ID from Google Cloud Console.
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# ── AI features ─────────────────────────────────────────────────────────────

ANTHROPIC_API_KEY=sk-ant-...
# Set to false to disable /api/ai endpoints without removing the key.
AI_ENABLED=true

# ── Data pipeline API keys ───────────────────────────────────────────────────

# FBI Crime Data Explorer API key — required for the safety-api pipeline task.
FBI_API_KEY=

# OpenAQ API key — required for the air-quality pipeline task.
OPENAQ_API_KEY=

# ── Optional ─────────────────────────────────────────────────────────────────

PORT=3000
NODE_ENV=development

# Comma-separated allowed CORS origins (default: http://localhost:5173)
CLIENT_ORIGINS=http://localhost:5173

# Set to true to skip Google sign-in locally (localhost-only; hard-blocked in production).
DEV_AUTH_BYPASS=false

# Firestore emulator address — routes all Firestore traffic to the local emulator.
# Run: firebase emulators:start --only firestore
# FIRESTORE_EMULATOR_HOST=localhost:8080
